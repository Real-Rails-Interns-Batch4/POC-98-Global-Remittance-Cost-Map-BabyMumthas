# ============================================================
# Backend Environment Variables (.env.example)
# Copy this file to .env and fill in the values.
# ============================================================

# Server configuration
APP_HOST=0.0.0.0
APP_PORT=8000

# Allowed CORS origins (comma-separated)
# Use * for development, restrict in production.
CORS_ORIGINS=http://localhost:3000

# World Bank Remittance Prices Worldwide API
# Reference: https://rfrm.worldbank.org
WORLD_BANK_API_URL=https://api.worldbank.org/v2

# European Central Bank Data Portal (SDMX API)
# Reference: https://data.ecb.europa.eu
ECB_API_URL=https://data-api.ecb.europa.eu/service

# IMF Financial Access Survey (future adapter)
# Reference: https://data.imf.org
IMF_FAS_API_URL=https://dataservices.imf.org/REST/SDMX_JSON.svc
